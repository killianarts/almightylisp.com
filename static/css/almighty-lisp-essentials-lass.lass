           :--font-berkeley "'Berkeley Mono', ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, Consolas, 'DejaVu Sans Mono', monospace"
           :--font-berkeley-thin "'Berkeley Mono Thin', ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, Consolas, 'DejaVu Sans Mono', monospace"
           :--font-berkeley-black "'Berkeley Mono Black', ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, Consolas, 'DejaVu Sans Mono', monospace"
           :--font-berkeley-uc "'Berkeley Mono UltraCondensed', ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, Consolas, 'DejaVu Sans Mono', monospace"
           :--font-berkeley-uc-thin "'Berkeley Mono Thin UltraCondensed', ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, Consolas, 'DejaVu Sans Mono', monospace"
           :--font-berkeley-uc-black "'Berkeley Mono ExtraBold UltraCondensed', ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, Consolas, 'DejaVu Sans Mono', monospace"
           :--font-bodoni "Bodoni 72 Smallcaps"
           :--font-heading "League Gothic"
           :--font-code "var(--font-berkeley)"
           :--font-link "var(--font-berkeley-uc)"
           :--font-hero "League Gothic Tall"
           :--font-serif "'Instrument Serif', serif"
           )
          (:font-face
           :font-family "'Berkeley Mono'"
           :font-style normal
           :font-width 400
           :font-display swap
           :src "local('Berkeley Mono') format('truetype'), url('/static/assets/fonts/BerkeleyMono-Regular.ttf') format('truetype')")
          (:font-face
           :font-family "'Berkeley Mono Thin'"
           :font-style normal
           :font-display swap
           :src "local('Berkeley Mono Thin') format('truetype'), url('/static/assets/fonts/BerkeleyMono-Light.ttf') format('truetype')")
          (:font-face
           :font-family "'Berkeley Mono Black'"
           :font-style normal
           :font-display swap
           :src "local('Berkeley Mono Black') format('truetype'), url('/static/assets/fonts/BerkeleyMono-Black.ttf') format('truetype')")
          (:font-face
           :font-family "'Berkeley Mono UltraCondensed'"
           :font-style condensed
           :font-weight 400
           :font-display swap
           :src "local('Berkeley Mono UltraCondensed') format('truetype'), url('/static/assets/fonts/BerkeleyMono-UltraCondensed.ttf') format('truetype')")
          (:font-face
           :font-family "'League Gothic'"
           :font-width 100
           :font-display swap
           :src "local('League Gothic') format('truetype'), url('/static/assets/fonts/LeagueGothic-Regular-VariableFont_wdth.ttf') format('truetype')")
          (:font-face
           :font-family "'League Gothic Tall'"
           :font-width 100
           :font-display swap
           :font-stretch 75%
           :src "local('League Gothic') format('truetype'), url('/static/assets/fonts/LeagueGothic-Regular-VariableFont_wdth.ttf') format('truetype')")
          (body
            :background-image (url "../../static/assets/images/bg-dot-pattern.png")
            :background-color #(primary-700)
            :background-repeat repeat
            :color #(primary-50))
          (a
            :color #(accent-400)
            :text-decoration underline
            :font-family "Berkeley Mono UltraCondensed"
            :transition all
            :transition-duration 300ms
            :text-shadow 1px 1px 0px #(accent-950))
          ((:and a :hover)
           :color #(accent-200))))


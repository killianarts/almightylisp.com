  (:layer components
          (article.book
           :font-family "'Instrument Serif'"
           :size 1rem
           :color #(primary-50))
          ((article.book (:or h1 h2 h3 h4 h5 h6))
           :font-size 2rem
           :font-family "'League Gothic'")
          ((article.book ((:or h1 h2 h3 h4 h5 h6) + span))
           :font-size 0.8rem
           :color #(accent-400))))
(:layer modules)
(:layer utilities)

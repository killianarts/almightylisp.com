 (code :class "code-block-source lisp" "(defparameter *almighty-list* '(this is almighty common lisp))
(nth 4 *almighty-list*)
                                        ; => LISP
(nth 5 *almighty-list*)
                                        ; => NIL
(nth 99 *almighty-list*)
                                        ; => NIL"))))
